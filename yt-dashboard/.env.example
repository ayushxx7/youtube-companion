# YouTube Dashboard Environment Configuration
# Copy this file to .env and fill in your values

# YouTube Data API v3 key (required for all metrics)
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# YouTube channel handle or ID (default: @thevibecoder69)
# Can be a handle like "@thevibecoder69" or a channel ID like "UC..."
YOUTUBE_CHANNEL_ID=@thevibecoder69

# YouTube Studio OAuth (optional — needed for impressions, CTR, retention)
# Leave blank until you're ready to connect Studio analytics
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
